server {
    listen 80;
    server_name {{DOMAIN}};

    client_max_body_size 20M;

    location = /favicon.ico { access_log off; log_not_found off; }

    location /static/ {
        alias /var/www/{{CLIENT_SLUG}}/staticfiles/;
    }

    location /media/ {
        alias /var/www/{{CLIENT_SLUG}}/media/;
    }

    location / {
        include proxy_params;
        proxy_pass http://unix:/var/www/{{CLIENT_SLUG}}/gunicorn.sock;
    }
}
