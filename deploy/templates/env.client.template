# Copy to /var/www/{{CLIENT_SLUG}}/.env
# Replace placeholders before deploy.

DJANGO_SECRET_KEY={{GENERATE_UNIQUE_SECRET_KEY}}
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS={{DOMAIN}}
DJANGO_CSRF_TRUSTED_ORIGINS=https://{{DOMAIN}}
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

DB_NAME={{DB_NAME}}
DB_USER={{DB_USER}}
DB_PASSWORD={{DB_PASSWORD}}
DB_HOST=127.0.0.1
DB_PORT=5432

DEPLOY_CLIENT_NAME={{CLIENT_NAME}}
DEPLOY_SUPERUSER_PASSWORD=Lyo@22999

