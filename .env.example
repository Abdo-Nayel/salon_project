# Copy to .env and fill in real values before deploying.
# cp .env.example .env

DJANGO_SECRET_KEY=change-me-to-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=ahmedatef.erpbylyomastech.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://ahmedatef.erpbylyomastech.com
# After certbot HTTPS, set both to True:
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True

DB_NAME=ahmedatefdb
DB_USER=ahmedatef_user
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# Deploy superuser (auto-created by: python manage.py ensure_deploy_superuser)
DEPLOY_CLIENT_NAME=Ahmedatef
DEPLOY_SUPERUSER_PASSWORD=Lyo@22999

